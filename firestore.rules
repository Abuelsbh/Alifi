rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default rule: Deny all access unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow admin full access - check: custom claims OR admins collection (no function)
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    // Allow authenticated users to read and write their own user profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin messages - users can only read their own messages
    match /admin_messages/{document} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // User notifications subcollection
    match /users/{userId}/notifications/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Pet Stores - public read for active stores, admin write
    match /petStores/{document} {
      allow read: if resource.data.isActive == true;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    // Veterinarians - public read for active vets, admin write
    match /veterinarians/{document} {
      allow read: if resource.data.isActive == true;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Advertisements collection - public read for active ads, admin write
    match /advertisements/{document} {
      allow read: if resource.data.isActive == true;
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Locations collection - public read for active locations, admin can read/write all
    match /locations/{document} {
      allow read: if resource.data.isActive == true || (request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ));
      allow create, update, delete: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Admins collection - multiple admins with different emails
    match /admins/{adminId} {
        allow read: if request.auth != null && (
          request.auth.token.admin == true ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
        allow create: if (request.auth != null && (
          request.auth.token.admin == true ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        )) || (request.auth != null && request.auth.uid == adminId && (
          request.auth.token.email == 'admin@alifi.com' ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.customClaims.admin == true
        ));
        allow update, delete: if request.auth != null && (
          request.auth.token.admin == true ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    // Report Collections (lost_pets, found_pets, adoption_pets, breeding_pets)
    match /lost_pets/{document} {
      allow read: if resource.data.status == 'approved' || (request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /found_pets/{document} {
      allow read: if resource.data.status == 'approved' || (request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /adoption_pets/{document} {
      allow read: if resource.data.status == 'approved' || (request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /breeding_pets/{document} {
      allow read: if resource.data.status == 'approved' || (request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
  }
} 